<launch>

    <!-- Load URDF with adjustable lidar_frame->camera chain -->
    <param name="robot_description"
       command="cat $(find manual_camera_lidar_calib)/urdf/camera_rig_static_joints.urdf" />

    <!-- Joint State Publisher GUI (publishes /joint_states) -->
    <node name="joint_state_publisher_gui" pkg="joint_state_publisher_gui" type="joint_state_publisher_gui" output="screen" />

    <!-- Robot State Publisher (publishes TF) -->
    <node name="robot_state_publisher" pkg="robot_state_publisher" type="robot_state_publisher" output="screen" />

</launch>